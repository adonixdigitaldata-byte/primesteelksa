# SMTP Configuration for Contact Form Submissions
# Copy this file to .env.local and fill in the values with your actual SMTP credentials

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="PrimeSteel KSA" <noreply@primesteelksa.com>
